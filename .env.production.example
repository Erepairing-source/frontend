# Production / AWS – copy to .env.local (or set in CI) before building.
# Build: npm run build (NEXT_PUBLIC_API_URL is baked in at build time).

# Your AWS API URL (e.g. API Gateway or load-balanced backend). Must end with /api/v1.
# Example: https://xxx.execute-api.ap-south-1.amazonaws.com/api/v1
NEXT_PUBLIC_API_URL=https://YOUR-AWS-API-URL/api/v1

# Optional: runtime override in public/config.js (window.__API_BASE__) so one build works with any backend.
