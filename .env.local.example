# Copy to .env.local and fill in your values.

# Backend API base URL (used at build time). Required for production/AWS so the app does not call localhost.
# Local dev: http://localhost:8000/api/v1
# Production: https://your-api.example.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional runtime override: edit public/config.js and set window.__API_BASE__ = 'https://your-api.com/api/v1'
# so one build works against any backend without rebuilding.

# Google Maps JavaScript API (free tier: $200/month credit)
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Enable "Maps JavaScript API"
# 2. Create credentials → API key → (optional) restrict by HTTP referrer for your domain
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
